# ============================================================
# PR Review Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit your .env file to git.

# -------------------------------------------------------
# Anthropic API Key
# Get it from: https://console.anthropic.com → API Keys
# -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant.....

# -------------------------------------------------------
# GitHub Personal Access Token
# Create at: GitHub → Settings → Developer settings →
#             Personal access tokens → Tokens (classic)
# Required scopes: repo (or pull_requests:write + contents:read)
# -------------------------------------------------------
GITHUB_TOKEN=ghp_....
# -------------------------------------------------------
# GitHub Webhook Secret
# A random string you choose when setting up the webhook.
# GitHub uses this to sign webhook payloads so you can
# verify they actually came from GitHub.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
# -------------------------------------------------------
GITHUB_WEBHOOK_SECRET=a_secret_message
# -------------------------------------------------------
# Server Configuration (optional)
# -------------------------------------------------------
PORT=8000
